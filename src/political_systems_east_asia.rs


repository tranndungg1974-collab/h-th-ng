            "Hệ thống Leninist một đảng lãnh đạo. Quốc hội Nhân dân Toàn quốc là cơ quan lập pháp cao nhất nhưng thực tế quyền lực tập trung vào Bộ Chính trị và Tổng Bí thư.",
            false,
        ),
    );

    // Nhật Bản
    systems.insert(
        "Japan".to_string(),
        PoliticalSystem::new(
