// political_systems_east_asia.rs
// Chương trình Rust mô tả hệ thống chính trị của các nước Á Đông (East Asia)

use std::collections::HashMap;

#[derive(Debug, Clone)]
struct PoliticalSystem {
    country: String,
    system_type: String,        // Cộng hòa, Quân chủ lập hiến, Cộng hòa xã hội chủ nghĩa, v.v.
    head_of_state: String,
    head_of_government: String,
    ruling_party: String,
    description: String,
    multi_party: bool,
}

impl PoliticalSystem {
    fn new(
        country: &str,
        system_type: &str,
        head_of_state: &str,
        head_of_government: &str,
        ruling_party: &str,
        description: &str,
        multi_party: bool,
    ) -> Self {
        PoliticalSystem {
            country: country.to_string(),
            system_type: system_type.to_string(),
            head_of_state: head_of_state.to_string(),
            head_of_government: head_of_government.to_string(),
            ruling_party: ruling_party.to_string(),
            description: description.to_string(),
            multi_party,
        }
    }

    fn print(&self) {
        println!("=== {} ===", self.country);
        println!("Hệ thống: {}", self.system_type);
        println!("Nguyên thủ quốc gia: {}", self.head_of_state);
        println!("Người đứng đầu chính phủ: {}", self.head_of_government);
        println!("Đảng cầm quyền: {}", self.ruling_party);
        println!("Đa đảng: {}", if self.multi_party { "Có" } else { "Không" });
        println!("Mô tả: {}\n", self.description);
    }
}

fn main() {
    let mut systems: HashMap<String, PoliticalSystem> = HashMap::new();

    // Trung Quốc
    systems.insert(
